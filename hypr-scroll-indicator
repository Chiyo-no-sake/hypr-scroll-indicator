#!/bin/sh
# Wrapper that sets LD_PRELOAD for gtk4-layer-shell and launches the indicator.
# Installed by `make install` alongside the Python script.

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# Find libgtk4-layer-shell and set LD_PRELOAD.
# The library must be preloaded before GTK4 initializes so that layer-shell
# can hook into it. Having the GI typelib alone is not sufficient.
if [ -z "$LD_PRELOAD" ] || ! echo "$LD_PRELOAD" | grep -q "libgtk4-layer-shell"; then
    for path in \
        /usr/lib64/libgtk4-layer-shell.so.0 \
        /usr/lib/libgtk4-layer-shell.so.0 \
        /usr/lib/x86_64-linux-gnu/libgtk4-layer-shell.so.0 \
        /usr/lib/aarch64-linux-gnu/libgtk4-layer-shell.so.0 \
        /usr/local/lib64/libgtk4-layer-shell.so.0 \
        /usr/local/lib/libgtk4-layer-shell.so.0; do
        if [ -f "$path" ]; then
            export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}$path"
            break
        fi
    done

    # Fallback: ask ldconfig
    if ! echo "${LD_PRELOAD:-}" | grep -q "libgtk4-layer-shell"; then
        LIB="$(ldconfig -p 2>/dev/null | grep -o '/[^ ]*libgtk4-layer-shell.so.0' | head -1)"
        if [ -n "$LIB" ]; then
            export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}$LIB"
        fi
    fi
fi

exec /usr/bin/python3 "$SCRIPT_DIR/hypr-scroll-indicator.py" "$@"
